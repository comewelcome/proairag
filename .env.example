# ============================================================
# ProAiRag Environment Configuration
# ============================================================
# Copy this file to .env and fill in the actual values.
# NEVER commit .env to version control.
# ============================================================

# PostgreSQL (required)
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/proairag

# Neo4j (required)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-neo4j-password

# JWT secret (required — generate with: python -c "import secrets; print(secrets.token_urlsafe(32))")
SECRET_KEY=your-jwt-secret-key

# Super admin (optional — auto-seeded at startup)
SUPER_ADMIN_EMAIL=admin@example.com
SUPER_ADMIN_PASSWORD=super-admin-password

# Dashboard demo tenants (optional)
DASHBOARD_LOGIN_1=demo1@company.com
DASHBOARD_PASSWORD_1=demo-password-1
DASHBOARD_LOGIN_2=demo2@company.com
DASHBOARD_PASSWORD_2=demo-password-2

# Embedding model (optional)
EMBEDDING_MODEL=sentence-transformers/paraphrase-MiniLM-L3-v2
EMBEDDING_DIMENSION=384

# RAG settings (optional)
CHUNK_SIZE=512
CHUNK_OVERLAP=64
TOP_K=5

# LLM provider (optional — openai | ollama)
LLM_PROVIDER=openai
OPENAI_API_KEY=your-openai-key
OPENAI_API_BASE=http://localhost:1234/v1
OPENAI_MODEL=Qwen3.6-27B-UD-Q5_K_XL.gguf
LLM_MAX_TOKENS=500

# Ollama fallback (optional)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# Server (optional)
API_HOST=0.0.0.0
API_PORT=8000

# JWT settings (optional)
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=24
