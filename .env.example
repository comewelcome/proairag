# ProAiRag - Environment Configuration
# Copy to .env and fill in actual values. Never commit .env.

# PostgreSQL (required)
DATABASE_URL=postgresql+asyncpg://YOUR_USER:YOUR_PASSWORD@localhost:5432/proairag

# Neo4j (required)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-neo4j-password-here

# JWT (required)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-jwt-secret-here

# API
API_HOST=0.0.0.0
API_PORT=8000

# JWT settings
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=24

# Embedding
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384

# RAG
CHUNK_SIZE=512
CHUNK_OVERLAP=64
TOP_K=5

# LLM provider (default: OpenAI-compatible API on localhost:1234)
LLM_PROVIDER=openai
OPENAI_API_KEY=sk-...your-key...
OPENAI_API_BASE=http://localhost:1234/v1
OPENAI_MODEL=gpt-4o-mini

# Ollama fallback (uncomment to use instead)
# LLM_PROVIDER=ollama
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.1

# MCP Server (optional)
# API_KEY=sk-...

# Test credentials (integration tests only)
# TEST_AEROTECH_API_KEY=test-only-aerotech-key
# TEST_DATAVAULT_API_KEY=test-only-datavault-key
# TEST_USER_PASSWORD=test-user-password

# Super admin global (auto-seeded at startup)
# SUPER_ADMIN_EMAIL=superadmin@proairag.com
# SUPER_ADMIN_PASSWORD=super-admin-password-here

# Dashboard auto-seed tenants (DASHBOARD_LOGIN_N + DASHBOARD_PASSWORD_N)
# DASHBOARD_LOGIN_1=admin@acme.com
# DASHBOARD_PASSWORD_1=password123
# DASHBOARD_LOGIN_2=admin@another.com
# DASHBOARD_PASSWORD_2=password456
