# ProAirAg Environment Configuration
# Copy this file to .env and fill in your actual values.
# Never commit .env to version control.

# PostgreSQL (required)
DATABASE_URL=postgresql+asyncpg://YOUR_USER:YOUR_PASSWORD@localhost:5432/proairag

# Neo4j (required)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-neo4j-password-here

# JWT signing secret (required — use a random 256-bit key)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-jwt-secret-here

# API host/port
API_HOST=0.0.0.0
API_PORT=8000

# JWT settings
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=24

# Embedding
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384

# RAG settings
CHUNK_SIZE=512
CHUNK_OVERLAP=64
TOP_K=5

# Optional: LLM providers
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.1

# MCP Server (optional — for tenant resolution)
# API_KEY=sk-...

# Test credentials (for integration tests only)
# TEST_AEROTECH_API_KEY=test-only-aerotech-key
# TEST_DATAVAULT_API_KEY=test-only-datavault-key
# TEST_USER_PASSWORD=test-user-password
